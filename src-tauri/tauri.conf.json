{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Hello Agent",
  "version": "0.1.1",
  "identifier": "com.wonseokhan.helloagent",
  "build": {
    "beforeDevCommand": "pnpm dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "pnpm build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "Hello, Agent",
        "width": 880,
        "height": 700,
        "minWidth": 740,
        "minHeight": 580,
        "center": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
