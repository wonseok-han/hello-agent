{
  "$schema": "../gen/schemas/desktop-schema.json",
  "identifier": "default",
  "description": "Capability for the main window",
  "windows": ["main"],
  "permissions": [
    "core:default",
    "opener:default",
    "store:default",
    "dialog:default",
    "updater:default",
    "process:default",
    {
      "identifier": "opener:allow-open-url",
      "allow": [{ "url": "https://*" }]
    },
    {
      "identifier": "opener:allow-open-path",
      "allow": [{ "path": "$HOME/Documents/**" }]
    }
  ]
}
